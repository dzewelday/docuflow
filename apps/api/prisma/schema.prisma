generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
}

model Document {
  id            String         @id @default(uuid())
  filename      String
  status        DocumentStatus @default(PENDING)
  extractedData Json?
  createdAt     DateTime       @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  PENDING_UPLOAD
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

enum StorageProvider {
  LOCAL
  S3
}

model Document {
  id                String          @id @default(uuid())
  filename          String
  status            DocumentStatus  @default(PENDING_UPLOAD)
  storageProvider   StorageProvider @default(LOCAL)
  storageKey        String
  mimeType          String
  sizeBytes         Int
  uploadedAt        DateTime?
  processingStartedAt DateTime?
  completedAt       DateTime?
  errorMessage      String?
  extractedText     String?
  extractedData     Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([status, createdAt])
}

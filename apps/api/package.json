{
  "name": "@docuflow/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "RUST_LOG=trace prisma migrate dev --name init"
  },
  "dependencies": {
    "@docuflow/shared": "^0.0.0",
    "@hono/node-server": "^1.19.11",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^16.6.1",
    "hono": "^4.12.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "prisma": "^7.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  }
}

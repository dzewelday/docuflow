DATABASE_URL="postgresql://postgres:postgres@localhost:5432/docuflow?schema=public"
CORS_ORIGIN="http://localhost:3000"
NUXT_PUBLIC_API_BASE="http://localhost:3001"
API_BASE_URL="http://localhost:3001"
MAX_UPLOAD_SIZE_BYTES="10485760"
ALLOWED_UPLOAD_MIME_TYPES="application/pdf,image/png,image/jpeg,text/plain"
UPLOAD_SIGNING_SECRET="docuflow-local-signing-secret"
INTERNAL_EVENT_TOKEN="docuflow-internal-token"
LOCAL_STORAGE_DIR="/tmp/docuflow-storage"
WORKER_POLL_INTERVAL_MS="2000"
